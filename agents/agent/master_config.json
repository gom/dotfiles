{
  "colorScheme": "tokyo night",
  "trustedWorkspaces": [],
  "agents": {
    "antigravity": {
      "hooks": {
        "BeforeTool": [
          {
            "matcher": "run_shell_command|read_file|read_many_files|grep_search|search_file_content|web_fetch|activate_skill|mcp__plugin_context-mode|mcp__context-mode|mcp__(?!.*context-mode)",
            "hooks": [
              {
                "type": "command",
                "command": "context-mode hook gemini-cli beforetool"
              }
            ]
          }
        ],
        "AfterTool": [
          {
            "matcher": "",
            "hooks": [
              {
                "type": "command",
                "command": "context-mode hook gemini-cli aftertool"
              }
            ]
          }
        ],
        "PreCompress": [
          {
            "matcher": "",
            "hooks": [
              {
                "type": "command",
                "command": "context-mode hook gemini-cli precompress"
              }
            ]
          }
        ],
        "SessionStart": [
          {
            "matcher": "",
            "hooks": [
              {
                "type": "command",
                "command": "context-mode hook gemini-cli sessionstart"
              }
            ]
          }
        ]
      }
    },
    "claude": {},
    "codex": {
      "features": {
        "plugin_hooks": true,
        "hooks": true
      }
    },
    "opencode": {
      "plugins": ["context-mode"],
      "model": "ollama/qwen3.6:35b-a3b",
      "small_model": "ollama/gemma4:e4b",
      "provider": {
        "ollama": {
          "npm": "@ai-sdk/openai-compatible",
          "name": "Ollama (local)",
          "options": {
            "baseURL": "{env:OLLAMA_BASE_URL}/v1"
          },
          "models": {
            "qwen3.6:27b": {
              "name": "Qwen 3.6 27B"
            },
            "qwen3.6:35b-a3b": {
              "name": "Qwen 3.6 35B A3B"
            },
            "gemma4:26b": {
              "name": "Gemma 4 26B"
            },
            "gemma4:e4b": {
              "name": "Gemma 4 E4B"
            }
          }
        }
      }
    }
  },
  "permissions": {
    "allow": [
      "command(ls)",
      "command(cat)",
      "command(git status)",
      "command(git log)",
      "command(docker compose)",
      "command(mkdir)",
      "command(pwd)",
      "command(find)",
      "command(git rev-parse)",
      "command(git remote)",
      "command(diff)",
      "command(date)",
      "command(echo)",
      "command(git add)"
    ],
    "ask": ["command(git commit)", "command(git push)"]
  },
  "mcp_servers": {
    "github": {
      "command": "/usr/local/bin/github-mcp-server",
      "args": ["stdio"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "$GITHUB_TOKEN"
      }
    },
    "context-mode": {
      "command": "context-mode"
    },
    "drawio": {
      "serverUrl": "https://mcp.draw.io/mcp"
    },
    "tavily": {
      "serverUrl": "https://mcp.tavily.com/mcp/?tavilyApiKey=$TAVILY_API_KEY"
    },
    "serena": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "claude-code",
        "--project-from-cwd"
      ]
    }
  }
}
