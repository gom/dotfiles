{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(pwd)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(realpath *)",
      "Bash(tree)",
      "Bash(tree *)",
      "Bash(jq *)",
      "Bash(diff *)",
      "Bash(date)",
      "Bash(date *)",
      "Bash(echo *)",

      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git rev-parse *)",
      "Bash(git remote)",
      "Bash(git remote *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git ls-files)",
      "Bash(git ls-files *)",
      "Bash(git grep *)",
      "Bash(git branch)",
      "Bash(git branch --show-current)",
      "Bash(git branch --list)",
      "Bash(git branch --list *)",
      "Bash(git config --get *)",
      "Bash(git config --list)",
      "Bash(git config --list *)",
      "Bash(git add *)"
    ],
    "ask": [
      "Bash(find)",
      "Bash(find *)",
      "Bash(mkdir *)",

      "Bash(git commit)",
      "Bash(git commit *)",
      "Bash(git push)",
      "Bash(git push *)",
      "Bash(git checkout)",
      "Bash(git checkout *)",
      "Bash(git switch)",
      "Bash(git switch *)",
      "Bash(git restore)",
      "Bash(git restore *)",
      "Bash(git reset)",
      "Bash(git reset *)",
      "Bash(git merge)",
      "Bash(git merge *)",
      "Bash(git rebase)",
      "Bash(git rebase *)",
      "Bash(git cherry-pick)",
      "Bash(git cherry-pick *)",
      "Bash(git revert)",
      "Bash(git revert *)",
      "Bash(git fetch)",
      "Bash(git fetch *)",
      "Bash(git pull)",
      "Bash(git pull *)",

      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(mv *)",
      "Bash(cp *)",
      "Bash(chmod *)",
      "Bash(chown *)",

      "Bash(bash)",
      "Bash(bash *)",
      "Bash(sh)",
      "Bash(sh *)",
      "Bash(zsh)",
      "Bash(zsh *)"
    ],
    "deny": [
      "Bash(sudo)",
      "Bash(sudo *)",

      "Bash(git reset --hard)",
      "Bash(git reset --hard *)",
      "Bash(git clean)",
      "Bash(git clean *)",

      "Bash(git push --force)",
      "Bash(git push --force *)",
      "Bash(git push * --force)",
      "Bash(git push * --force *)",
      "Bash(git push -f)",
      "Bash(git push -f *)",
      "Bash(git push * -f)",
      "Bash(git push * -f *)"
    ]
  }
}
