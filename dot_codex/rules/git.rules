# Read-only Git commands
prefix_rule(
    pattern = ["git", "status"],
    decision = "allow",
)

prefix_rule(
    pattern = ["git", "log"],
    decision = "allow",
)

prefix_rule(
    pattern = ["git", "rev-parse"],
    decision = "allow",
)

prefix_rule(
    pattern = ["git", "remote"],
    decision = "allow",
)

prefix_rule(
    pattern = ["git", "diff"],
    decision = "allow",
)

prefix_rule(
    pattern = ["git", "show"],
    decision = "allow",
)

prefix_rule(
    pattern = ["git", "ls-files"],
    decision = "allow",
)

prefix_rule(
    pattern = ["git", "grep"],
    decision = "allow",
)

prefix_rule(
    pattern = ["git", "branch", "--show-current"],
    decision = "allow",
)

prefix_rule(
    pattern = ["git", "branch", "--list"],
    decision = "allow",
)

prefix_rule(
    pattern = ["git", "config", "--get"],
    decision = "allow",
)

prefix_rule(
    pattern = ["git", "config", "--list"],
    decision = "allow",
)

# Staging is a write operation, but usually low-risk enough to allow
prefix_rule(
    pattern = ["git", "add"],
    decision = "allow",
)

# Git operations that can change working tree, refs, history, or remote state
prefix_rule(
    pattern = ["git", "checkout"],
    decision = "prompt",
    justification = "Checkout can change the working tree.",
)

prefix_rule(
    pattern = ["git", "switch"],
    decision = "prompt",
    justification = "Switching branches can change the working tree.",
)

prefix_rule(
    pattern = ["git", "restore"],
    decision = "prompt",
    justification = "Restore can discard local changes.",
)

prefix_rule(
    pattern = ["git", "reset"],
    decision = "prompt",
    justification = "Reset can move refs or discard changes.",
)

prefix_rule(
    pattern = ["git", "reset", "--hard"],
    decision = "forbidden",
    justification = "Hard reset can irreversibly discard local work. Ask the user to run it manually.",
)

prefix_rule(
    pattern = ["git", "clean"],
    decision = "forbidden",
    justification = "git clean can delete untracked files. Ask the user to run it manually.",
)

prefix_rule(
    pattern = ["git", "merge"],
    decision = "prompt",
    justification = "Merge changes history and working tree state.",
)

prefix_rule(
    pattern = ["git", "rebase"],
    decision = "prompt",
    justification = "Rebase rewrites commit history.",
)

prefix_rule(
    pattern = ["git", "cherry-pick"],
    decision = "prompt",
    justification = "Cherry-pick changes history and working tree state.",
)

prefix_rule(
    pattern = ["git", "revert"],
    decision = "prompt",
    justification = "Revert creates history changes.",
)

prefix_rule(
    pattern = ["git", "fetch"],
    decision = "prompt",
    justification = "Fetch contacts a remote and updates refs.",
)

prefix_rule(
    pattern = ["git", "pull"],
    decision = "prompt",
    justification = "Pull contacts a remote and can change the working tree.",
)

prefix_rule(
    pattern = ["git", "commit"],
    decision = "prompt",
    justification = "Creating commits should be explicitly approved.",
)

prefix_rule(
    pattern = ["git", "push"],
    decision = "prompt",
    justification = "Pushing changes to a remote should be explicitly approved.",
)

prefix_rule(
    pattern = ["git", "push", "--force"],
    decision = "forbidden",
    justification = "Force-push can overwrite remote history. Ask the user to run it manually.",
)

prefix_rule(
    pattern = ["git", "push", "-f"],
    decision = "forbidden",
    justification = "Force-push can overwrite remote history. Ask the user to run it manually.",
)
