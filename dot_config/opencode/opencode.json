{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "*": "ask",

      "ls": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "pwd": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "wc *": "allow",
      "file *": "allow",
      "stat *": "allow",
      "realpath *": "allow",
      "tree": "allow",
      "tree *": "allow",
      "jq *": "allow",
      "diff *": "allow",
      "date": "allow",
      "date *": "allow",
      "echo *": "allow",

      "git status": "allow",
      "git status *": "allow",
      "git log": "allow",
      "git log *": "allow",
      "git rev-parse *": "allow",
      "git remote": "allow",
      "git remote *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git show *": "allow",
      "git ls-files": "allow",
      "git ls-files *": "allow",
      "git grep *": "allow",
      "git branch": "allow",
      "git branch --show-current": "allow",
      "git branch --list": "allow",
      "git branch --list *": "allow",
      "git config --get *": "allow",
      "git config --list": "allow",
      "git config --list *": "allow",
      "git add *": "allow",

      "find": "ask",
      "find *": "ask",
      "mkdir *": "ask",

      "git commit": "ask",
      "git commit *": "ask",
      "git push": "ask",
      "git push *": "ask",
      "git checkout": "ask",
      "git checkout *": "ask",
      "git switch": "ask",
      "git switch *": "ask",
      "git restore": "ask",
      "git restore *": "ask",
      "git reset": "ask",
      "git reset *": "ask",
      "git merge": "ask",
      "git merge *": "ask",
      "git rebase": "ask",
      "git rebase *": "ask",
      "git cherry-pick": "ask",
      "git cherry-pick *": "ask",
      "git revert": "ask",
      "git revert *": "ask",
      "git fetch": "ask",
      "git fetch *": "ask",
      "git pull": "ask",
      "git pull *": "ask",

      "rm *": "ask",
      "rmdir *": "ask",
      "mv *": "ask",
      "cp *": "ask",
      "chmod *": "ask",
      "chown *": "ask",

      "bash": "ask",
      "bash *": "ask",
      "sh": "ask",
      "sh *": "ask",
      "zsh": "ask",
      "zsh *": "ask",

      "sudo": "deny",
      "sudo *": "deny",

      "git reset --hard": "deny",
      "git reset --hard *": "deny",
      "git clean": "deny",
      "git clean *": "deny",

      "git push --force": "deny",
      "git push --force *": "deny",
      "git push * --force": "deny",
      "git push * --force *": "deny",
      "git push -f": "deny",
      "git push -f *": "deny",
      "git push * -f": "deny",
      "git push * -f *": "deny"
    }
  },
  "mcp": {
    "github": {
      "type": "local",
      "command": ["/usr/local/bin/github-mcp-server", "stdio"],
      "enabled": true,
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "$GITHUB_TOKEN"
      }
    },
    "drawio": {
      "type": "remote",
      "url": "https://mcp.draw.io/mcp",
      "enabled": true
    },
    "tavily": {
      "type": "remote",
      "url": "https://mcp.tavily.com/mcp/?tavilyApiKey=$TAVILY_API_KEY",
      "enabled": true
    },
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "claude-code",
        "--project-from-cwd"
      ],
      "enabled": true
    },
    "headroom": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "headroom-ai[mcp]",
        "headroom",
        "mcp",
        "serve"
      ]
    }
  },
  "plugin": ["context-mode"],
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "{env:OLLAMA_BASE_URL}/v1"
      },
      "models": {
        "qwen3.6:27b": {
          "name": "Qwen 3.6 27B"
        },
        "qwen3.6:35b-a3b": {
          "name": "Qwen 3.6 35B A3B"
        },
        "gemma4:26b": {
          "name": "Gemma 4 26B"
        },
        "gemma4:12b": {
          "name": "Gemma 4 12B"
        },
        "gemma4:e4b": {
          "name": "Gemma 4 E4B"
        }
      }
    },
    "openrouter" : {
      "models": {
        "~z-ai/glm-5.2":{
          "options": {
            "provider": {
              "only": ["z-ai", "novita"],
              "allow_fallbacks": false
            }
          }
        },
        "~deepseek/deepseek-v4-pro": {
          "options": {
            "provider": {
              "only": ["deepseek", "baidu"],
              "allow_fallbacks": false
            }
          }
        },
        "~moonshotai/kimi-k2.7-code": {
          "options": {
            "provider": {
              "only": ["moonshotai", "novita"],
              "allow_fallbacks": false
            }
          }
        },
        "~xiaomi/mimo-v2.5-pro": {
          "options": {
            "provider": {
              "only": ["xiaomi", "novita"],
              "allow_fallbacks": false
            }
          }
        },
        "~qwen/qwen3.7-max": {},
        "~deepseek/deepseek-v4-flash": {
          "options": {
            "provider": {
              "only": ["deepseek", "baidu"],
              "allow_fallbacks": false
            }
          }
        },
        "~minimax/minimax-m3": {
          "options": {
            "provider": {
              "only": ["minimax", "novita"],
              "allow_fallbacks": false
            }
          }
        }
      }
    }
  },
  "enabled_providers": ["openrouter"],
  "model": "openrouter/deepseel/deepseek-v4-pro",
  "small_model": "openrouter/openai/gpt-oss-120b"
}
