{
  "colorScheme": "tokyo night",
  "enableTerminalSandbox": true,
  "hooks": {
    "BeforeTool": [
      {
        "matcher": "run_shell_command|read_file|read_many_files|grep_search|search_file_content|web_fetch|activate_skill|mcp__plugin_context-mode|mcp__context-mode|mcp__(?!.*context-mode)",
        "hooks": [
          {
            "type": "command",
            "command": "context-mode hook gemini-cli beforetool"
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "context-mode hook gemini-cli aftertool"
          }
        ]
      }
    ],
    "PreCompress": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "context-mode hook gemini-cli precompress"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "context-mode hook gemini-cli sessionstart"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "command(ls)",
      "command(cat)",
      "command(pwd)",
      "command(grep)",
      "command(rg)",
      "command(head)",
      "command(tail)",
      "command(wc)",
      "command(file)",
      "command(stat)",
      "command(realpath)",
      "command(tree)",
      "command(jq)",
      "command(diff)",
      "command(date)",
      "command(echo)",
      "command(git status)",
      "command(git log)",
      "command(git rev-parse)",
      "command(git remote)",
      "command(git diff)",
      "command(git show)",
      "command(git ls-files)",
      "command(git grep)",
      "command(git branch --show-current)",
      "command(git branch --list)",
      "command(git config --get)",
      "command(git config --list)",
      "command(git add)"
    ],
    "deny": [
      "command(sudo)",
      "command(git reset --hard)",
      "command(git clean)",
      "command(git push --force)",
      "command(git push -f)"
    ],
    "ask": [
      "command(find)",
      "command(mkdir)",
      "command(git commit)",
      "command(git push)",
      "command(git checkout)",
      "command(git switch)",
      "command(git restore)",
      "command(git reset)",
      "command(git merge)",
      "command(git rebase)",
      "command(git cherry-pick)",
      "command(git revert)",
      "command(git fetch)",
      "command(git pull)",
      "command(rm)",
      "command(rmdir)",
      "command(mv)",
      "command(cp)",
      "command(chmod)",
      "command(chown)",
      "command(bash)",
      "command(sh)",
      "command(zsh)"
    ]
  },
  "statusLine": {
    "type": "",
    "command": "",
    "enabled": true
  },
  "subagents": [],
  "trustedWorkspaces": []
}
