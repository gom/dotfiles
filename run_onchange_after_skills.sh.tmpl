#!/usr/bin/env bash
# Hash: {{ include "agents/manifest.json" | sha256sum }}
set -e

MANIFEST="{{ .chezmoi.sourceDir }}/agents/manifest.json"

JQ_BIN="jq"
if ! command -v jq &>/dev/null; then
    for path in "$HOME/.local/share/mise/installs/jq/latest/jq" \
                "$HOME/.local/share/mise/installs/jq"/*/jq \
                "$HOME/.local/share/mise/shims/jq"; do
        if [ -x "$path" ]; then
            JQ_BIN="$path"
            break
        fi
    done
fi

SKILLS_BIN="skills"
if ! command -v skills &>/dev/null; then
    for path in "$HOME/.local/share/mise/shims/skills" \
                "$HOME/.local/share/mise/installs/npm-skills/latest/bin/skills" \
                "$HOME/.local/share/mise/installs/npm-skills"/*/bin/skills; do
        if [ -x "$path" ]; then
            SKILLS_BIN="$path"
            break
        fi
    done
fi

install_skills() {
    local source="$1"; shift
    local flags=()
    for skill in "$@"; do flags+=(--skill "$skill"); done
    for agent in antigravity claude-code codex opencode; do
        "$SKILLS_BIN" add "$source" "${flags[@]}" --global --agent "$agent" --yes || true
    done
}

# Read global skills from manifest and install
while IFS= read -u 3 -r entry; do
    if echo "$entry" | "$JQ_BIN" -e '.source' &>/dev/null; then
        src=$(echo "$entry" | "$JQ_BIN" -r '.source')
        mapfile -t skills < <(echo "$entry" | "$JQ_BIN" -r '.skills[]')
        install_skills "$src" "${skills[@]}"
    else
        src=$(echo "$entry" | "$JQ_BIN" -r '.')
        install_skills "$src"
    fi
done 3< <("$JQ_BIN" -c '.skills.global[]' "$MANIFEST")
